            </div>
          </div>
          <button onClick={save} style={{ background:ok?GL:G, border:`1.5px solid ${ok?GB:"transparent"}`, color:ok?G:"#fff", fontWeight:600, fontSize:13, padding:11, borderRadius:9, cursor:"pointer", transition:"all .2s" }}>
            {ok?"✓ Alert activated!":"+ Create Alert"}
          </button>
        </div>
      ) : (
        <div style={{ background:GL, border:`1.5px solid ${GB}`, borderRadius:9, padding:16, textAlign:"center", color:G, fontWeight:500, cursor:"pointer" }}>
          ⚡ Upgrade to Pro for unlimited alerts
        </div>
      )}
    </div>
  )
}

// ── Account panel
function AccountPanel({ user, plan, onPlanChange, onSignOut }) {
  return (
    <div style={{ background:"#fff", border:"1.5px solid #e8e8e4", borderRadius:16, padding:24, maxWidth:480 }}>
      <div style={{ fontFamily:"'Playfair Display',serif", fontSize:20, fontWeight:600, color:"#0a0a0a", marginBottom:20 }}>Account</div>
      <div style={{ display:"flex", gap:14, alignItems:"center", marginBottom:22 }}>
        <div style={{ width:48, height:48, borderRadius:"50%", background:GL, border:`1.5px solid ${GB}`, display:"flex", alignItems:"center", justifyContent:"center", fontSize:20 }}>🏗️</div>
        <div>
          <div style={{ fontSize:15, fontWeight:500, color:"#0a0a0a" }}>{user.name}</div>
          <div style={{ fontSize:12, color:"#999" }}>{user.email}</div>
        </div>
      </div>
      <div style={{ display:"flex", flexDirection:"column", gap:8, marginBottom:18 }}>
        {Object.entries(PLANS).map(([key,p])=>(
          <div key={key} style={{ background:plan===key?GL:"#f8f8f5", border:`1.5px solid ${plan===key?GB:"#e8e8e4"}`, borderRadius:10, padding:"12px 14px", cursor:"pointer" }} onClick={()=>onPlanChange(key)}>
            <div style={{ display:"flex", justifyContent:"space-between" }}>
              <div style={{ fontWeight:500, color:plan===key?G:"#0a0a0a", fontSize:14 }}>{p.name}</div>
              <div style={{ fontWeight:500, color:plan===key?G:"#666" }}>{p.price===0?"Free":`$${p.price}/mo`}</div>
            </div>
            <div style={{ color:"#aaa", fontSize:11, marginTop:3 }}>{p.ai===Infinity?"Unlimited":p.ai} AI analyses · {p.alerts===Infinity?"Unlimited":p.alerts} alerts</div>
            {plan===key&&<div style={{ color:G, fontSize:10, fontWeight:600, marginTop:4 }}>● Current plan</div>}
          </div>
        ))}
      </div>
      <button onClick={onSignOut} style={{ background:"#f5f5f0", border:"1px solid #e0e0da", color:"#888", fontSize:13, padding:"9px 18px", borderRadius:8, cursor:"pointer" }}>Sign Out</button>
    </div>
  )
}

// ── LOGIN SCREEN
function Login({ onLogin }) {
  const [mode, setMode] = useState("login")
  const [email, setEmail] = useState("")
  const [pass,  setPass]  = useState("")
  const [name,  setName]  = useState("")
  const [err,   setErr]   = useState("")
  const [busy,  setBusy]  = useState(false)

  const submit = async () => {
    if (!email || !pass) { setErr("Please enter your email and password"); return }
    setBusy(true); setErr("")
    try {
      const d = mode==="signup" ? await sb.signUp(email, pass) : await sb.signIn(email, pass)
      if (d?.access_token || d?.demo) {
        onLogin({ name: name||email.split("@")[0], email, token: d.access_token||"demo", id: d.user?.id||"demo" })
      } else {
        setErr(d?.error_description || d?.message || "Something went wrong — try again")
      }
    } catch { onLogin({ name: name||email.split("@")[0], email, token:"demo", id:"demo" }) }
    setBusy(false)
  }

  return (
    <div style={{ minHeight:"100vh", background:"#000", display:"flex", alignItems:"center", justifyContent:"center", padding:20, fontFamily:"Inter,'Helvetica Neue',sans-serif" }}>
      <div style={{ width:"100%", maxWidth:400 }}>
        <div style={{ textAlign:"center", marginBottom:28 }}>
          <img src={LOGO} alt="Deal Radar" style={{ width:290, maxWidth:"90%", display:"block", margin:"0 auto 10px" }} />
          <div style={{ color:"#555", fontSize:10, letterSpacing:3, textTransform:"uppercase" }}>Heavy Equipment & Real Estate Intelligence</div>
        </div>
        <div style={{ background:"#111", border:"1.5px solid #222", borderRadius:16, padding:28 }}>
          <div style={{ display:"flex", background:"#1a1a1a", borderRadius:9, padding:3, marginBottom:22 }}>
            {[["login","Sign In"],["signup","Create Account"]].map(([m,l])=>(
              <button key={m} onClick={()=>{setMode(m);setErr("")}} style={{ flex:1, background:mode===m?"#2a2a2a":"transparent", border:"none", color:mode===m?"#fff":"#555", padding:"9px", fontSize:13, fontWeight:mode===m?500:400, cursor:"pointer", borderRadius:7, transition:"all .15s" }}>{l}</button>
            ))}
          </div>
          <div style={{ display:"flex", flexDirection:"column", gap:11 }}>
            {mode==="signup" && <input value={name} onChange={e=>setName(e.target.value)} placeholder="Full name" style={{ background:"#1a1a1a", border:"1.5px solid #2a2a2a", borderRadius:9, padding:"12px 14px", color:"#fff", fontSize:13, outline:"none", fontFamily:"inherit" }} />}
            <input value={email} onChange={e=>setEmail(e.target.value)} onKeyDown={e=>e.key==="Enter"&&submit()} placeholder="Email address" type="email" style={{ background:"#1a1a1a", border:"1.5px solid #2a2a2a", borderRadius:9, padding:"12px 14px", color:"#fff", fontSize:13, outline:"none", fontFamily:"inherit" }} />
            <input value={pass} onChange={e=>setPass(e.target.value)} onKeyDown={e=>e.key==="Enter"&&submit()} placeholder="Password" type="password" style={{ background:"#1a1a1a", border:"1.5px solid #2a2a2a", borderRadius:9, padding:"12px 14px", color:"#fff", fontSize:13, outline:"none", fontFamily:"inherit" }} />
            {err && <div style={{ color:"#f87171", fontSize:12 }}>{err}</div>}
            <button onClick={submit} disabled={busy} style={{ background:G, border:"none", color:"#fff", fontWeight:600, fontSize:14, padding:13, borderRadius:9, cursor:"pointer", opacity:busy?.7:1, fontFamily:"'Playfair Display',serif" }}>
              {busy?"Working…":mode==="login"?"Sign In →":"Create Account →"}
            </button>
          </div>
          <div style={{ textAlign:"center", color:"#444", fontSize:11, marginTop:14 }}>Free plan · No credit card required</div>
        </div>
      </div>
    </div>
  )
}

// ── MAIN APP
function App() {
  const [user,    setUser]    = useState(null)
  const [plan,    setPlan]    = useState("free")
  const [tab,     setTab]     = useState("equipment")
  const [cat,     setCat]     = useState("All")
  const [minSc,   setMinSc]   = useState(0)
  const [sort,    setSort]    = useState("score")
  const [saved,   setSaved]   = useState(new Set())
  const [search,  setSearch]  = useState("")
  const [modal,   setModal]   = useState(null)   // null | "ai" | "upgrade"
  const [aiListing,setAiL]   = useState(null)
  const [aiUsed,  setAiUsed] = useState(0)

  const EQUIP_CATS = ["All","Excavators","Skid Steers","Dozers","Trucks & Trailers","Wheel Loaders"]
  const RE_CATS    = ["All","Single Family","Multi-Family","Commercial","Land"]

  const allListings = tab==="equipment" ? DEMO.filter(l=>l.type==="equipment")
                    : tab==="realestate"? DEMO.filter(l=>l.type==="realestate")
                    : DEMO

  const filtered = allListings
    .filter(l => tab!=="saved" || saved.has(l.id))
    .filter(l => cat==="All" || l.category===cat)
    .filter(l => l.score >= minSc)
    .filter(l => !search || l.title.toLowerCase().includes(search.toLowerCase()) || l.location.toLowerCase().includes(search.toLowerCase()))
    .sort((a,b)=>sort==="score"?b.score-a.score:sort==="savings"?(b.value-b.bid)-(a.value-a.bid):a.bid-b.bid)

  const hotCount = DEMO.filter(l=>l.score>=85).length
  const cats = tab==="equipment"?EQUIP_CATS:tab==="realestate"?RE_CATS:["All"]

  if (!user) return <Login onLogin={u=>{setUser(u)}} />

  return (
    <>
      <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
      <style>{`* { box-sizing: border-box; margin: 0; padding: 0; } body { font-family: Inter, "Helvetica Neue", sans-serif; }`}</style>

      <div style={{ minHeight:"100vh", background:"#f5f5f0" }}>

        {/* NAV */}
        <div style={{ background:"#0a0a0a", height:56, padding:"0 24px", display:"flex", alignItems:"center", justifyContent:"space-between", position:"sticky", top:0, zIndex:100 }}>
          <img src={LOGO} alt="Deal Radar" style={{ height:33 }} />
          <div style={{ display:"flex", alignItems:"center", gap:12 }}>
            <div style={{ background:`${G}20`, border:`1px solid ${G}40`, borderRadius:7, padding:"5px 11px", fontSize:11, color:G, fontWeight:500 }}>🔥 {hotCount} Hot Deals</div>
            <div style={{ width:6, height:6, borderRadius:"50%", background:G }} />
            <span style={{ fontSize:10, color:"#555", letterSpacing:1 }}>LIVE</span>
            {plan==="free" && <button onClick={()=>setModal("upgrade")} style={{ background:G, border:"none", color:"#fff", fontWeight:600, fontSize:11, padding:"7px 14px", borderRadius:7, cursor:"pointer" }}>⚡ Upgrade</button>}
          </div>
        </div>

        {/* STATS BAR */}
        <div style={{ background:"#fff", borderBottom:"1px solid #e8e8e4", padding:"10px 24px", display:"flex", gap:28, overflowX:"auto" }}>
          {[["Active Listings",DEMO.length],["Hot Deals",hotCount],["Sources","5+"],["Your Plan",PLANS[plan]?.name]].map(([lbl,val])=>(
            <div key={lbl} style={{ minWidth:80 }}>
              <div style={{ color:"#bbb", fontSize:9, textTransform:"uppercase", letterSpacing:1 }}>{lbl}</div>
              <div style={{ fontFamily:"'Playfair Display',serif", fontSize:19, fontWeight:600, color:"#0a0a0a" }}>{val}</div>
            </div>
          ))}
        </div>

        {/* TABS */}
        <div style={{ background:"#fff", borderBottom:"1px solid #e8e8e4", padding:"0 24px", display:"flex", overflowX:"auto" }}>
          {[{k:"equipment",l:"🏗️ Equipment"},{k:"realestate",l:"🏠 Real Estate"},{k:"saved",l:`★ Saved (${saved.size})`},{k:"alerts",l:"🔔 Alerts"},{k:"account",l:"👤 Account"}].map(t=>(
            <button key={t.k} onClick={()=>{setTab(t.k);setCat("All")}} style={{ background:"none", border:"none", borderBottom:tab===t.k?`2px solid ${G}`:"2px solid transparent", color:tab===t.k?G:"#aaa", padding:"13px 18px", fontSize:13, fontWeight:tab===t.k?500:400, cursor:"pointer", whiteSpace:"nowrap" }}>
              {t.l}
            </button>
          ))}
        </div>

        {/* CONTENT */}
        <div style={{ maxWidth:1200, margin:"0 auto", padding:"20px 16px" }}>
          {tab==="alerts"  ? <AlertsPanel plan={plan} userToken={user.token} />
          :tab==="account" ? <AccountPanel user={user} plan={plan} onPlanChange={setPlan} onSignOut={()=>setUser(null)} />
          :(
            <div style={{ display:"grid", gridTemplateColumns:"200px 1fr", gap:20 }}>

              {/* SIDEBAR */}
              <div style={{ display:"flex", flexDirection:"column", gap:12 }}>
                <div style={{ background:"#fff", border:"1px solid #e8e8e4", borderRadius:12, padding:14 }}>
                  <div style={{ color:"#bbb", fontSize:9, textTransform:"uppercase", letterSpacing:1.5, marginBottom:7 }}>Search</div>
                  <input value={search} onChange={e=>setSearch(e.target.value)} placeholder="Equipment or city…" style={{ ...inp(), padding:"7px 10px", fontSize:12 }} />
                </div>

                {(tab==="equipment"||tab==="realestate") && (
                  <div style={{ background:"#fff", border:"1px solid #e8e8e4", borderRadius:12, padding:14 }}>
                    <div style={{ color:"#bbb", fontSize:9, textTransform:"uppercase", letterSpacing:1.5, marginBottom:8 }}>Category</div>
                    {cats.map(c=>(
                      <button key={c} onClick={()=>setCat(c)} style={{ display:"block", width:"100%", textAlign:"left", background:cat===c?GL:"none", border:cat===c?`1px solid ${GB}`:"1px solid transparent", color:cat===c?G:"#666", padding:"6px 9px", borderRadius:6, fontSize:12, cursor:"pointer", marginBottom:2, fontWeight:cat===c?500:400 }}>{c}</button>
                    ))}
                  </div>
                )}

                <div style={{ background:"#fff", border:"1px solid #e8e8e4", borderRadius:12, padding:14 }}>
                  <div style={{ color:"#bbb", fontSize:9, textTransform:"uppercase", letterSpacing:1.5, marginBottom:7 }}>Min score: <span style={{color:G,fontWeight:500}}>{minSc}</span></div>
                  <input type="range" min={0} max={90} value={minSc} onChange={e=>setMinSc(+e.target.value)} style={{ width:"100%", accentColor:G }} />
                  <div style={{ display:"flex", justifyContent:"space-between", fontSize:9, color:"#ccc", marginTop:4 }}><span>Any</span><span>90+</span></div>
                </div>

                <div style={{ background:GL, border:`1px solid ${GB}`, borderRadius:12, padding:14 }}>
                  <div style={{ color:G, fontSize:9, textTransform:"uppercase", letterSpacing:1.5, fontWeight:600, marginBottom:8 }}>Your stats</div>
                  {[["AI analyses",`${aiUsed} / ${PLANS[plan].ai===Infinity?"∞":PLANS[plan].ai}`],["Saved",saved.size],["Plan",PLANS[plan].name]].map(([k,v])=>(
                    <div key={k} style={{ display:"flex", justifyContent:"space-between", marginBottom:5 }}>
                      <span style={{ color:"#888", fontSize:11 }}>{k}</span>
                      <span style={{ color:G, fontSize:11, fontWeight:500 }}>{v}</span>
                    </div>
                  ))}
                  {plan==="free"&&<button onClick={()=>setModal("upgrade")} style={{ width:"100%", background:G, border:"none", color:"#fff", fontSize:11, fontWeight:500, padding:7, borderRadius:7, cursor:"pointer", marginTop:8 }}>⚡ Go Pro</button>}
                </div>
              </div>

              {/* FEED */}
              <div>
                <div style={{ display:"flex", justifyContent:"space-between", alignItems:"center", marginBottom:14 }}>
                  <div style={{ color:"#888", fontSize:13 }}><span style={{color:"#0a0a0a",fontWeight:500}}>{filtered.length}</span> deals found</div>
                  <select value={sort} onChange={e=>setSort(e.target.value)} style={{ background:"#fff", border:"1.5px solid #e0e0da", color:"#0a0a0a", padding:"7px 12px", borderRadius:8, fontSize:12, outline:"none", cursor:"pointer" }}>
                    <option value="score">Best score first</option>
                    <option value="savings">Biggest savings</option>
                    <option value="price">Lowest price</option>
                  </select>
                </div>
                {filtered.length===0
                  ? <div style={{ textAlign:"center", padding:60, color:"#ccc" }}><div style={{ fontSize:36, marginBottom:10 }}>📡</div><div style={{color:"#999"}}>No deals match your filters</div></div>
                  : <div style={{ display:"grid", gridTemplateColumns:"repeat(auto-fill,minmax(295px,1fr))", gap:16 }}>
                      {filtered.map(L=>(
                        <Card key={L.id} L={L} plan={plan} aiUsed={aiUsed}
                          saved={saved.has(L.id)}
                          onSave={id=>setSaved(p=>{const n=new Set(p);n.has(id)?n.delete(id):n.add(id);return n})}
                          onAI={L=>{setAiL(L);setModal("ai")}}
                          onUpgrade={()=>setModal("upgrade")}
                        />
                      ))}
                    </div>}
              </div>
            </div>
          )}
        </div>

        {modal==="ai"      && <AIModal L={aiListing} onClose={()=>setModal(null)} onUsed={()=>setAiUsed(p=>p+1)} />}
        {modal==="upgrade" && <UpgradeModal onClose={()=>setModal(null)} onUpgrade={p=>{setPlan(p);setModal(null)}} />}
      </div>
    </>
  )
}


    const root = ReactDOM.createRoot(document.getElementById('root'));
    root.render(<App />);
  </script>
</body>
</html>
